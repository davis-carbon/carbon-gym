// Carbon Gym — Training Centre Management Platform
// Replaces Exercise.com white-label at home.carbontc.co

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  TRAINER
  STAFF
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PENDING_CANCELLATION
  SUSPENDED
}

enum LifecycleStage {
  LEAD
  PROSPECT
  CLIENT
  FORMER_CLIENT
}

enum BillingStatus {
  PAID
  NON_BILLED
  BILLED
  PAST_DUE
  CANCELLED
}

enum PlanStatus {
  DRAFT
  PUBLISHED
  ASSIGNED
  ARCHIVED
}

enum ServiceType {
  APPOINTMENT
  CLASS
}

enum VisitStatus {
  RESERVED
  CONFIRMED
  COMPLETED
  CANCELLED
  EARLY_CANCEL
  NO_SHOW
  LATE_CANCEL
}

enum PackageType {
  SESSION_PACK
  MEMBERSHIP
  TRIAL
  DROP_IN
}

enum PackageBillingCycle {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  ONE_TIME
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  REFUNDED
  PENDING
}

enum MessageSenderType {
  STAFF
  CLIENT
}

enum AutomationTrigger {
  DAYS_AFTER_PURCHASE
  DAYS_AFTER_SIGNUP
  DAYS_BEFORE_EXPIRY
  DAYS_BEFORE_BIRTHDAY
  LOW_SESSIONS_REMAINING
  PLAN_ENDING_SOON
  TAG_ADDED
  TAG_REMOVED
  ON_FIRST_LOGIN
  MANUAL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ForceType {
  PUSH
  PULL
  STATIC
  DYNAMIC
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  QUADRICEPS
  HAMSTRINGS
  GLUTES
  CALVES
  CORE
  ABS
  OBLIQUES
  FULL_BODY
  CARDIO
  OTHER
}

enum AssessmentFieldType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
  DATE
  BOOLEAN
  SCALE
  TEXTAREA
  FILE
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  timezone  String   @default("America/Denver")
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  email     String?
  website   String?
  bio       String?
  autoReply String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff              StaffMember[]
  clients            Client[]
  tags               Tag[]
  groups             Group[]
  exercises          Exercise[]
  workoutPlans       WorkoutPlan[]
  locations          Location[]
  serviceCategories  ServiceCategory[]
  services           Service[]
  packages           Package[]
  appointments       Appointment[]
  assessments        Assessment[]
  resources          Resource[]
  videos             Video[]
  automations        Automation[]
  auditLogs          AuditLog[]
  messageThreads     MessageThread[]
  accountBalanceTransactions AccountBalanceTransaction[]
  serviceBalanceTransactions ServiceBalanceTransaction[]
  clientNoteFields   ClientNoteField[]
  timeEntries        StaffTimeEntry[]
  orgLinks           OrgLink[]
  emailTemplates     EmailTemplate[]
}

// ─────────────────────────────────────────────
// TIME CARD
// ─────────────────────────────────────────────

model StaffTimeEntry {
  id             String      @id @default(cuid())
  organizationId String
  staffId        String
  clockedIn      DateTime
  clockedOut     DateTime?
  note           String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  staff        StaffMember  @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@index([staffId])
}

// ─────────────────────────────────────────────
// ORG LINKS
// ─────────────────────────────────────────────

model OrgLink {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  url            String
  type           String   @default("custom")  // "booking", "affiliate", "custom"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ─────────────────────────────────────────────
// EMAIL TEMPLATES
// ─────────────────────────────────────────────

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  subject        String
  body           String
  trigger        String?  // "welcome", "appointment_reminder", "payment_receipt", "custom"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ─────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────

model StaffMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @unique // Supabase auth.users id
  role           Role     @default(TRAINER)
  firstName      String
  lastName       String
  email          String
  phone          String?
  bio            String?
  avatarUrl      String?
  color           String   @default("#6B7280") // Calendar display color
  dashboardConfig Json?                        // Persisted card layout [{id,type,timeRange}]
  specialties     String[]                     // e.g. ["Strength & Conditioning", "Nutrition"]
  certifications  String[]                     // e.g. ["NASM-CPT", "CrossFit L2"]
  linkedinUrl     String?
  instagramUrl    String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization        Organization          @relation(fields: [organizationId], references: [id])
  timeEntries         StaffTimeEntry[]
  assignedClients     Client[]
  createdExercises    Exercise[]
  createdPlans        WorkoutPlan[]
  planAssignments     PlanAssignment[]
  appointments        Appointment[]
  trainerNotes        TrainerNote[]
  nutritionPlans      NutritionPlan[]
  measurements        Measurement[]         @relation("MeasurementTakenBy")
  updatedNoteValues   ClientNoteValue[]     @relation("NoteValueUpdatedBy")
  createdAssessments  Assessment[]
  createdResources    Resource[]
  createdVideos       Video[]
  uploadedProgressPhotos ProgressPhoto[]
  createdAutomations  Automation[]
  availabilitySchedules AvailabilitySchedule[]
  recurringMembers    RecurringMember[]
  trainedWorkouts     ClientWorkout[]       @relation("WorkoutTrainer")
  groupPosts          GroupPost[]
  groupPostComments   GroupPostComment[]
  recordedRepMaxes    RepMax[]              @relation("RepMaxRecordedBy")
  assessmentAssignments AssessmentAssignment[] @relation("AssignmentAssignedBy")

  @@index([organizationId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────────

model Client {
  id               String          @id @default(cuid())
  organizationId   String
  userId           String?         @unique // Supabase auth.users id (nullable — not all clients have portal access)
  firstName        String
  lastName         String
  email            String?
  phone            String?
  gender           Gender?
  birthDate        DateTime?
  address          String?
  city             String?
  state            String?
  zip              String?
  country          String?
  billingAddress   String?
  billingCity      String?
  billingState     String?
  billingZip       String?
  billingCountry   String?
  height           String?
  weight           String?
  profileImageUrl  String?
  aboutMe          String?
  signupDate       DateTime        @default(now())
  status           ClientStatus    @default(ACTIVE)
  lifecycleStage   LifecycleStage  @default(CLIENT)
  billingStatus    BillingStatus   @default(NON_BILLED)
  assignedStaffId  String?
  stripeCustomerId String?
  appPlatform      String?
  customStatus     String?
  customFields     Json            @default("{}")
  deletedAt        DateTime?       // Soft delete
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  assignedStaff    StaffMember?     @relation(fields: [assignedStaffId], references: [id])
  tags             ClientTag[]
  groups           ClientGroup[]
  clientPackages   ClientPackage[]
  payments         Payment[]
  measurements     Measurement[]
  trainerNotes     TrainerNote[]
  workoutLogs      WorkoutLog[]
  nutritionPlans   NutritionPlan[]
  nutritionLogs    NutritionLog[]
  assessmentSubmissions AssessmentSubmission[]
  resourceAssignments   ResourceAssignment[]
  videoAssignments      VideoAssignment[]
  progressPhotos        ProgressPhoto[]
  appointments     Appointment[]
  planAssignments  PlanAssignment[]
  recurringMembers RecurringMember[]
  messageParticipants MessageParticipant[]
  pushSubscriptions   ClientPushSubscription[]
  clientWorkouts      ClientWorkout[]
  groupPosts          GroupPost[]
  groupPostComments   GroupPostComment[]
  accountBalanceTransactions AccountBalanceTransaction[]
  serviceBalanceTransactions ServiceBalanceTransaction[]
  clientNoteValues   ClientNoteValue[]
  repMaxes           RepMax[]
  nutritionGoals        NutritionGoals[]
  nutritionFiles        NutritionFile[]
  assessmentAssignments AssessmentAssignment[]
  lifecycleEvents       ClientLifecycleEvent[]

  @@index([organizationId])
  @@index([assignedStaffId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
}

model ClientPushSubscription {
  id        String   @id @default(cuid())
  clientId  String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, endpoint])
}

// ─────────────────────────────────────────────
// TAGS & GROUPS
// ─────────────────────────────────────────────

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   @default("#6B7280")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  clients      ClientTag[]

  @@unique([organizationId, name])
}

model ClientTag {
  clientId String
  tagId    String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
}

model Group {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  imageUrl         String?
  isActive         Boolean  @default(true)
  // Collaboration features
  isPublic         Boolean  @default(false)
  publicSlug       String?  @unique
  maxMembers       Int?
  lifecycleOnJoin  String?
  allowClientPosts Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  members      ClientGroup[]
  posts        GroupPost[]

  @@index([organizationId])
  @@index([publicSlug])
}

model ClientGroup {
  clientId String
  groupId  String
  joinedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([clientId, groupId])
}

model GroupPost {
  id             String   @id @default(cuid())
  groupId        String
  staffAuthorId  String?
  clientAuthorId String?
  content        String
  mediaUrl       String?
  isAnnouncement Boolean  @default(false)
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group        Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  staffAuthor  StaffMember?       @relation(fields: [staffAuthorId], references: [id])
  clientAuthor Client?            @relation(fields: [clientAuthorId], references: [id])
  comments     GroupPostComment[]

  @@index([groupId, createdAt])
}

model GroupPostComment {
  id             String   @id @default(cuid())
  postId         String
  staffAuthorId  String?
  clientAuthorId String?
  content        String
  createdAt      DateTime @default(now())

  post         GroupPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  staffAuthor  StaffMember? @relation(fields: [staffAuthorId], references: [id])
  clientAuthor Client?      @relation(fields: [clientAuthorId], references: [id])

  @@index([postId])
}

// ─────────────────────────────────────────────
// EXERCISES
// ─────────────────────────────────────────────

model Exercise {
  id               String          @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  instructions     String?         // Legacy freetext; prefer steps[]
  muscleGroup      MuscleGroup?
  secondaryMuscles MuscleGroup[]
  difficultyLevel  DifficultyLevel?
  forceType        ForceType?
  equipment        String?
  videoUrl         String?         // Direct URL or YouTube watch URL
  youtubeVideoId   String?         // Extracted YouTube ID for embed
  thumbnailUrl     String?
  isActive         Boolean         @default(true)
  createdById      String?
  tags             String[]
  // Enhanced fields
  exerciseType     String?         // e.g. "Strength", "Cardio", "Mobility", "Plyometric"
  mechanics        String?         // e.g. "Compound", "Isolation"
  laterality       String?         // "Bilateral", "Unilateral", "Each Side"
  isEachSide       Boolean         @default(false)
  tempo            String?         // e.g. "3-1-2-0" (eccentric-pause-concentric-pause)
  steps            String[]        // Step-by-step instructions array
  tips             String[]        // Coaching tips
  variations       String[]        // Variation names (freetext)
  customFields     Json            @default("{}")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  createdBy       StaffMember?     @relation(fields: [createdById], references: [id])
  routineExercises RoutineExercise[]
  workoutLogExercises WorkoutLogExercise[]
  workoutBlockExercises WorkoutBlockExercise[]
  alternateFor     WorkoutAlternateExercise[]
  repMaxes         RepMax[]

  @@index([organizationId])
  @@index([muscleGroup])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// WORKOUT PLANS & ROUTINES
// ─────────────────────────────────────────────

model WorkoutPlan {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  description    String?
  sizeWeeks             Int        @default(4)
  status                PlanStatus @default(DRAFT)
  planType              String?
  createdById           String?
  tags                  String[]
  // Selling
  isSellable            Boolean    @default(false)
  price                 Float?
  checkoutDescription   String?
  welcomeMessage        String?
  thankYouMessage       String?
  // Plan settings
  difficulty            String?
  equipment             String[]
  frequency             String?
  objectives            String?
  requireWorkoutLogging Boolean    @default(false)
  autoStartPlanId       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id])
  createdBy       StaffMember?    @relation(fields: [createdById], references: [id])
  routines        PlanRoutine[]
  assignments     PlanAssignment[]
  clientWorkouts  ClientWorkout[] @relation("WorkoutFromPlan")

  @@index([organizationId])
  @@index([status])
}

model PlanRoutine {
  id         String   @id @default(cuid())
  planId     String
  dayNumber  Int
  weekNumber Int      @default(1)
  name       String?
  notes      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  plan      WorkoutPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]

  @@index([planId])
}

model RoutineExercise {
  id          String  @id @default(cuid())
  routineId   String
  exerciseId  String
  sets        Int?
  reps        String? // Can be "8-12" or "AMRAP"
  weight      String? // Can be "135lbs" or "bodyweight"
  restSeconds Int?
  duration    String? // For timed exercises
  tempo       String? // e.g., "3-1-2-0"
  notes       String?
  sortOrder   Int     @default(0)

  routine  PlanRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id])

  @@index([routineId])
}

model PlanAssignment {
  id           String    @id @default(cuid())
  planId       String
  clientId     String
  assignedById String?
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  plan       WorkoutPlan  @relation(fields: [planId], references: [id])
  client     Client       @relation(fields: [clientId], references: [id])
  assignedBy StaffMember? @relation(fields: [assignedById], references: [id])
  workoutLogs WorkoutLog[]

  @@index([clientId])
  @@index([planId])
}

// ─────────────────────────────────────────────
// CLIENT WORKOUTS (Calendar Builder)
// The core daily tool — trainers program workouts
// per client per day on the calendar view.
// ─────────────────────────────────────────────

model ClientWorkout {
  id             String    @id @default(cuid())
  clientId       String
  trainerId      String?
  planId         String?   // If created from a plan template
  title          String    @default("Workout") // e.g., "Aerobic", "Upper Body A"
  date           DateTime  // Which calendar day
  scheduledAt    DateTime? // Specific time if scheduled
  completedAt    DateTime? // When the client completed it
  isCompleted    Boolean   @default(false)
  totalTime      Int?      // Seconds
  totalWeight    Float?    // lbs total volume
  totalDistance   Float?    // miles
  totalReps      Int?
  totalCalories  Int?
  notes          String?   // Client-visible workout notes
  staffNotes     String?   // Private staff notes
  source         String    @default("calendar") // "calendar", "plan", "copied"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client  Client        @relation(fields: [clientId], references: [id])
  trainer StaffMember?  @relation("WorkoutTrainer", fields: [trainerId], references: [id])
  plan    WorkoutPlan?  @relation("WorkoutFromPlan", fields: [planId], references: [id])
  blocks  WorkoutBlock[]

  @@index([clientId, date])
  @@index([trainerId])
  @@index([date])
}

model WorkoutBlock {
  id          String  @id @default(cuid())
  workoutId   String
  name        String  @default("Block A") // "Block A", "Block B", etc.
  blockType   String  @default("Normal")  // "Normal", "Superset", "Circuit", "EMOM", "AMRAP", "Tabata"
  sortOrder   Int     @default(0)
  rounds      Int?    // Number of rounds (for Circuit, EMOM, etc.)
  notes       String? // Block-level notes visible to client

  workout   ClientWorkout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercises WorkoutBlockExercise[]

  @@index([workoutId])
}

model WorkoutBlockExercise {
  id              String  @id @default(cuid())
  blockId         String
  exerciseId      String
  sortOrder       Int     @default(0)
  notes           String?
  restSeconds     Int?    // Rest between sets (in seconds)
  restSecondsB    Int?    // Second rest value (MM part stored separately)
  overrideCalories Int?   // Override calories burned
  measurementType String  @default("reps,weight") // Comma-separated: reps,weight,time,distance,calories,rpe
  tempo           String?  // e.g., "3-0-1-0"
  intensity       String?  // e.g., "8/10"
  isAmrap         Boolean  @default(false)
  eachSide        Boolean  @default(false)
  progressions    Boolean  @default(false)
  saveAsRepMax    Boolean  @default(false)

  block      WorkoutBlock              @relation(fields: [blockId], references: [id], onDelete: Cascade)
  exercise   Exercise                  @relation(fields: [exerciseId], references: [id])
  sets       WorkoutBlockExerciseSet[]
  alternates WorkoutAlternateExercise[]

  @@index([blockId])
}

model WorkoutAlternateExercise {
  id              String @id @default(cuid())
  blockExerciseId String
  exerciseId      String
  sortOrder       Int    @default(0)

  blockExercise WorkoutBlockExercise @relation(fields: [blockExerciseId], references: [id], onDelete: Cascade)
  exercise      Exercise             @relation(fields: [exerciseId], references: [id])

  @@index([blockExerciseId])
}

model WorkoutBlockExerciseSet {
  id          String  @id @default(cuid())
  exerciseId  String  // References WorkoutBlockExercise.id
  setNumber   Int
  reps        Int?
  weight      Float?  // lbs or kg
  time        Int?    // Seconds (for timed exercises)
  distance    Float?  // Meters or miles
  calories    Int?
  rpe         Float?  // Rate of perceived exertion
  percentage  Float?  // % of 1RM (e.g. 75 = 75%)
  isCompleted Boolean @default(false) // Client marked as done
  actualReps    Int?    // What client actually did
  actualWeight  Float?
  actualTime    Int?
  actualDistance Float?
  actualCalories Int?

  blockExercise WorkoutBlockExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

// ─────────────────────────────────────────────
// WORKOUT LOGGING
// ─────────────────────────────────────────────

model WorkoutLog {
  id               String    @id @default(cuid())
  clientId         String
  planAssignmentId String?
  planId           String?
  planRoutineId    String?   // Which routine in the plan was completed
  date             DateTime  @default(now())
  completedAt      DateTime?
  durationMinutes  Int?
  notes            String?
  createdAt        DateTime  @default(now())

  client         Client          @relation(fields: [clientId], references: [id])
  planAssignment PlanAssignment? @relation(fields: [planAssignmentId], references: [id])
  exercises      WorkoutLogExercise[]

  @@index([clientId])
  @@index([date])
  @@index([planAssignmentId])
}

model WorkoutLogExercise {
  id           String @id @default(cuid())
  workoutLogId String
  exerciseId   String
  sets         Json   // Array of { reps: number, weight: number, duration?: number, rpe?: number }
  notes        String?

  workoutLog WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id])

  @@index([workoutLogId])
}

// ─────────────────────────────────────────────
// SCHEDULING
// ─────────────────────────────────────────────

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  city           String?
  state          String?
  zip            String?
  phone          String?
  timezone       String   @default("America/Denver")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id])
  services             Service[]
  appointments         Appointment[]
  availabilitySchedules AvailabilitySchedule[]

  @@index([organizationId])
}

model ServiceCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  services     Service[]

  @@index([organizationId])
}

model Service {
  id              String      @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  type            ServiceType @default(APPOINTMENT)
  categoryId      String?
  durationMinutes Int         @default(60)
  maxParticipants Int?        // For classes
  color           String      @default("#6B7280")
  locationId      String?
  requiresAsset   Boolean     @default(false)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  location     Location?        @relation(fields: [locationId], references: [id])
  appointments Appointment[]
  recurringMembers RecurringMember[]
  availabilitySlots AvailabilitySlot[] @relation("SlotServices")

  @@index([organizationId])
  @@index([type])
}

model Package {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  description    String?
  packageType    PackageType        @default(SESSION_PACK)
  billingCycle   PackageBillingCycle @default(MONTHLY)
  price          Float
  setupFee       Float              @default(0)
  sessionCount   Int?               // For session packs
  expiryDays     Int?               // Auto-expire after N days
  autoRenew      Boolean            @default(false)
  isActive       Boolean            @default(true)
  stripePriceId  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  clientPackages ClientPackage[]

  @@index([organizationId])
}

model ClientPackage {
  id                  String   @id @default(cuid())
  clientId            String
  packageId           String
  startDate           DateTime
  endDate             DateTime?
  sessionsRemaining   Int?
  sessionsUsed        Int      @default(0)
  status              String   @default("active") // active, expired, cancelled, paused
  stripeSubscriptionId String?
  cancelledAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id])
  package      Package      @relation(fields: [packageId], references: [id])
  appointments Appointment[]
  payments     Payment[]

  @@index([clientId])
  @@index([packageId])
  @@index([status])
}

model AvailabilitySchedule {
  id         String   @id @default(cuid())
  staffId    String
  locationId String?
  name       String   @default("Default")
  isDefault  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  staff    StaffMember        @relation(fields: [staffId], references: [id])
  location Location?          @relation(fields: [locationId], references: [id])
  slots    AvailabilitySlot[]

  @@index([staffId])
}

model AvailabilitySlot {
  id         String    @id @default(cuid())
  scheduleId String
  dayOfWeek  DayOfWeek
  startTime  String    // "09:00" (HH:mm)
  endTime    String    // "17:00" (HH:mm)

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  services Service[]            @relation("SlotServices")

  @@index([scheduleId])
}

model Appointment {
  id               String      @id @default(cuid())
  organizationId   String
  clientId         String
  staffId          String
  serviceId        String
  locationId       String?
  clientPackageId  String?
  scheduledAt      DateTime
  endAt            DateTime
  status           VisitStatus @default(RESERVED)
  notes            String?
  cancelledAt      DateTime?
  cancelReason     String?
  isRecurring      Boolean     @default(false)
  recurringMemberId String?
  reminderSentAt   DateTime?
  bookedAt         DateTime    @default(now())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  client          Client           @relation(fields: [clientId], references: [id])
  staff           StaffMember      @relation(fields: [staffId], references: [id])
  service         Service          @relation(fields: [serviceId], references: [id])
  location        Location?        @relation(fields: [locationId], references: [id])
  clientPackage   ClientPackage?   @relation(fields: [clientPackageId], references: [id])
  recurringMember RecurringMember? @relation(fields: [recurringMemberId], references: [id])

  @@index([organizationId])
  @@index([clientId])
  @@index([staffId])
  @@index([scheduledAt])
  @@index([status])
}

model RecurringMember {
  id        String    @id @default(cuid())
  clientId  String
  serviceId String
  staffId   String
  startDate DateTime
  endDate   DateTime?
  dayOfWeek DayOfWeek
  startTime String    // "09:00" (HH:mm)
  frequency String    @default("weekly") // "weekly", "biweekly"
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client       Client        @relation(fields: [clientId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  staff        StaffMember   @relation(fields: [staffId], references: [id])
  appointments Appointment[]

  @@index([clientId])
  @@index([staffId])
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  clientId              String
  clientPackageId       String?
  amount                Float
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeInvoiceId       String?
  invoiceNumber         String?       // Human-readable invoice ref e.g. INV-0042
  description           String?
  failureReason         String?
  refundedAmount        Float         @default(0)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())

  client        Client         @relation(fields: [clientId], references: [id])
  clientPackage ClientPackage? @relation(fields: [clientPackageId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([paidAt])
}

model AccountBalanceTransaction {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String
  amount         Float    // positive = credit, negative = debit
  description    String?
  runningBalance Float    @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model ServiceBalanceTransaction {
  id              String   @id @default(cuid())
  organizationId  String
  clientId        String
  amount          Float
  description     String?
  startingBalance Float    @default(0)
  endingBalance   Float    @default(0)
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

// ─────────────────────────────────────────────
// MEASUREMENTS & TRACKING
// ─────────────────────────────────────────────

model Measurement {
  id             String    @id @default(cuid())
  clientId       String
  date           DateTime
  weight         Float?
  bodyFatPercent Float?
  chest          Float?
  waist          Float?
  hips           Float?
  leftArm        Float?
  rightArm       Float?
  leftThigh      Float?
  rightThigh     Float?
  neck           Float?
  sleepHours     Float?
  energyLevel    Float?
  waterOunces    Float?
  stepsPerDay    Float?
  effort         Float?
  hunger         Float?
  cravings       Float?
  stress         Float?
  hrv            Float?
  notes          String?
  takenById      String?
  createdAt      DateTime  @default(now())

  client  Client       @relation(fields: [clientId], references: [id])
  takenBy StaffMember? @relation("MeasurementTakenBy", fields: [takenById], references: [id])

  @@index([clientId])
  @@index([date])
}

model TrainerNote {
  id        String    @id @default(cuid())
  clientId  String
  staffId   String
  title     String?
  content   String
  noteDate  DateTime?
  isPrivate Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client Client      @relation(fields: [clientId], references: [id])
  staff  StaffMember @relation(fields: [staffId], references: [id])

  @@index([clientId])
}

model ClientNoteField {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  values       ClientNoteValue[]

  @@index([organizationId])
}

model ClientNoteValue {
  id          String   @id @default(cuid())
  clientId    String
  fieldId     String
  content     String   @default("")
  updatedAt   DateTime @updatedAt
  updatedById String?

  client    Client          @relation(fields: [clientId], references: [id])
  field     ClientNoteField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  updatedBy StaffMember?    @relation("NoteValueUpdatedBy", fields: [updatedById], references: [id])

  @@unique([clientId, fieldId])
  @@index([clientId])
}

// ─────────────────────────────────────────────
// NUTRITION
// ─────────────────────────────────────────────

model NutritionPlan {
  id          String    @id @default(cuid())
  clientId    String
  createdById String?
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client    Client       @relation(fields: [clientId], references: [id])
  createdBy StaffMember? @relation(fields: [createdById], references: [id])
  meals     NutritionMeal[]

  @@index([clientId])
}

model NutritionMeal {
  id        String  @id @default(cuid())
  planId    String
  name      String  // "Breakfast", "Lunch", etc.
  dayNumber Int     @default(1)
  calories  Float?
  protein   Float?
  carbs     Float?
  fat       Float?
  notes     String?
  sortOrder Int     @default(0)

  plan NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model NutritionGoals {
  id                    String   @id @default(cuid())
  clientId              String
  dayType               String   @default("training") // "training" | "rest"
  carbs                 Float?
  fat                   Float?
  protein               Float?
  fiber                 Float?
  kcalPerGramCarbs      Float    @default(4)
  kcalPerGramFat        Float    @default(9)
  kcalPerGramProtein    Float    @default(4)
  kcalPerGramFiber      Float    @default(4)
  autoCalculateCalories Boolean  @default(true)
  totalCalories         Float?
  notes                 String?  // Shown/edited on the training day record only
  updatedAt             DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, dayType])
  @@index([clientId])
}

model NutritionFile {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model NutritionLog {
  id       String   @id @default(cuid())
  clientId String
  date     DateTime
  mealName String?
  description String?
  calories Float?
  protein  Float?
  carbs    Float?
  fat      Float?
  notes    String?
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([date])
}

// ─────────────────────────────────────────────
// ASSESSMENTS
// ─────────────────────────────────────────────

model Assessment {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  fields         Json     // Array of { name, label, type: AssessmentFieldType, options?, required? }
  isActive       Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id])
  createdBy    StaffMember?           @relation(fields: [createdById], references: [id])
  submissions  AssessmentSubmission[]
  assignments  AssessmentAssignment[]

  @@index([organizationId])
}

model AssessmentAssignment {
  id                    String    @id @default(cuid())
  assessmentId          String
  clientId              String
  assignedById          String?
  sendReminders         Boolean   @default(false)
  unassignAfterComplete Boolean   @default(false)
  assignedAt            DateTime  @default(now())
  completedAt           DateTime?

  assessment Assessment   @relation(fields: [assessmentId], references: [id])
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedBy StaffMember?  @relation("AssignmentAssignedBy", fields: [assignedById], references: [id])

  @@index([clientId])
  @@index([assessmentId])
}

model AssessmentSubmission {
  id           String   @id @default(cuid())
  assessmentId String
  clientId     String
  responses    Json     // Key-value pairs of field answers
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  client     Client     @relation(fields: [clientId], references: [id])

  @@index([assessmentId])
  @@index([clientId])
}

// ─────────────────────────────────────────────
// RESOURCES
// ─────────────────────────────────────────────

model Resource {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  fileUrl        String
  fileType       String?
  category       String?
  createdById    String?
  createdAt      DateTime @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id])
  createdBy    StaffMember?       @relation(fields: [createdById], references: [id])
  assignments  ResourceAssignment[]

  @@index([organizationId])
}

model ResourceAssignment {
  id         String    @id @default(cuid())
  resourceId String
  clientId   String
  assignedAt DateTime  @default(now())
  viewedAt   DateTime?

  resource Resource @relation(fields: [resourceId], references: [id])
  client   Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([resourceId])
}

// ─────────────────────────────────────────────
// PROGRESS PHOTOS
// ─────────────────────────────────────────────

model ProgressPhoto {
  id          String   @id @default(cuid())
  clientId    String
  fileUrl     String?  // uploaded file URL
  videoUrl    String?  // YouTube / Vimeo link
  caption     String?
  takenAt     DateTime @default(now())
  createdAt   DateTime @default(now())
  uploadedById String?

  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy StaffMember? @relation(fields: [uploadedById], references: [id])

  @@index([clientId])
}

// ─────────────────────────────────────────────
// VIDEOS
// ─────────────────────────────────────────────

model Video {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  videoUrl       String
  fileType       String?
  createdById    String?
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  createdBy    StaffMember?      @relation(fields: [createdById], references: [id])
  assignments  VideoAssignment[]

  @@index([organizationId])
}

model VideoAssignment {
  id         String    @id @default(cuid())
  videoId    String
  clientId   String
  assignedAt DateTime  @default(now())
  viewedAt   DateTime?

  video  Video  @relation(fields: [videoId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([videoId])
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model MessageThread {
  id             String   @id @default(cuid())
  organizationId String
  subject        String?
  isGroup        Boolean  @default(false)
  groupId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  participants MessageParticipant[]
  messages     Message[]

  @@index([organizationId])
}

model MessageParticipant {
  id         String            @id @default(cuid())
  threadId   String
  userId     String            // StaffMember.id or Client.id
  userType   MessageSenderType
  clientId   String?           // Populated if userType = CLIENT
  lastReadAt DateTime?

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  client Client?       @relation(fields: [clientId], references: [id])

  @@unique([threadId, userId])
  @@index([userId])
}

model Message {
  id          String            @id @default(cuid())
  threadId    String
  senderId    String            // StaffMember.id or Client.id
  senderType  MessageSenderType
  body        String
  scheduledAt DateTime?
  sentAt      DateTime          @default(now())
  createdAt   DateTime          @default(now())

  thread      MessageThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments MessageAttachment[]

  @@index([threadId])
  @@index([sentAt])
}

model MessageAttachment {
  id        String @id @default(cuid())
  messageId String
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ─────────────────────────────────────────────
// AUTOMATIONS
// ─────────────────────────────────────────────

model Automation {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  isActive       Boolean           @default(true)
  trigger        AutomationTrigger
  triggerValue   Int?              // e.g., number of days
  triggerProduct String?           // e.g., package name for purchase triggers
  filterCriteria Json              @default("{}") // Who it applies to
  actions        Json              // Array of { type, config } action definitions
  createdById    String?
  lastRunAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    StaffMember? @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// REP MAXES
// ─────────────────────────────────────────────

model RepMax {
  id           String   @id @default(cuid())
  clientId     String
  exerciseId   String
  reps         Int
  weight       Float    // lbs
  recordedAt   DateTime @default(now())
  recordedById String?
  notes        String?
  createdAt    DateTime @default(now())

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise   Exercise    @relation(fields: [exerciseId], references: [id])
  recordedBy StaffMember? @relation("RepMaxRecordedBy", fields: [recordedById], references: [id])

  @@index([clientId])
  @@index([exerciseId])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model ClientLifecycleEvent {
  id         String   @id @default(cuid())
  clientId   String
  fromStage  String?  // null on initial assignment
  toStage    String
  source     String?  // e.g. "Default Lifecycle Stage", "Manual", automation name
  createdAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json     @default("{}")
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
